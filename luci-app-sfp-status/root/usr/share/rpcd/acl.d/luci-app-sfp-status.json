{
  "luci-app-sfp-status": {
    "description": "Grant UCI and RPC access to LuCI app SFP status",
    "read": {
      "uci": [
        "sfp-status"
      ],
      "ubus": {
        "luci.sfp-status": [
          "getInterfaces",
          "getStatus"
        ]
      }
    },
    "write": {
      "uci": [
        "sfp-status"
      ]
    }
  }
}